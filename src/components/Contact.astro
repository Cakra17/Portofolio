---
import { Icon } from 'astro-icon/components';
import Reveal from './Reveal.astro';
import { site } from '../data/site';
---

<section id="contact" class="relative px-6 py-32">
  <Reveal class="mx-auto max-w-3xl text-center">
    <p class="eyebrow mb-3">Get in Touch</p>
    <h2 class="text-3xl font-bold text-text md:text-4xl">Let's work together</h2>
    <p class="mx-auto mt-4 max-w-xl leading-relaxed text-muted">
      I'm open to discussing backend roles, freelance projects,
      or just exchanging ideas about systems and software.
    </p>

    <div class="card mx-auto mt-10 max-w-xl p-8 shadow-lg shadow-black/5">
      <p class="mb-6 text-muted">Reach out via email or connect with me on GitHub &amp; LinkedIn.</p>

      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a href={`mailto:${site.email}`} class="btn-primary w-full sm:w-auto">
          <Icon name="lucide:mail" class="h-4 w-4" />
          Say Hello
        </a>
        <a href={site.social.github} target="_blank" rel="noopener" class="btn-ghost w-full sm:w-auto">
          <Icon name="lucide:github" class="h-4 w-4" />
          GitHub
        </a>
        <a href={site.social.linkedin} target="_blank" rel="noopener" class="btn-ghost w-full sm:w-auto">
          <Icon name="lucide:linkedin" class="h-4 w-4" />
          LinkedIn
        </a>
      </div>
    </div>

    <p class="mt-8 text-sm text-muted">
      Prefer async communication? Email works best.
    </p>
  </Reveal>
</section>
