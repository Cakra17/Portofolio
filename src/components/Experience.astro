---
import Reveal from './Reveal.astro';
import { experiences } from '../data/experience';
---

<section id="experience" class="relative py-25">
  <div class="section-shell">
    <Reveal class="mx-auto mb-20 max-w-2xl text-center">
      <p class="eyebrow mb-3">Career</p>
      <h2 class="text-3xl font-bold text-text md:text-4xl">Experience</h2>
      <p class="mt-4 text-muted">
        My professional journey focusing on backend systems, APIs,
        and production-ready software.
      </p>
    </Reveal>

    <div class="relative mx-auto max-w-3xl">
      <div class="absolute left-[7px] top-1 h-full w-px bg-border"></div>

      {experiences.map((exp, i) => (
        <Reveal delay={i * 100} class="relative pb-12 pl-12 last:pb-0">
          <div class="absolute left-0 top-1 h-4 w-4 rounded-full border-2 border-bg bg-accent ring-4 ring-accent/20"></div>

          <div class="card p-6">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h3 class="text-lg font-semibold text-text">{exp.role}</h3>
              <span class="font-mono text-xs text-muted">{exp.period}</span>
            </div>

            <p class="mt-1 text-sm font-medium text-accent">{exp.company}</p>

            <p class="mt-4 text-sm leading-relaxed text-muted">{exp.description}</p>

            <ul class="mt-4 space-y-2 text-sm text-muted">
              {exp.highlights.map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
                  {item}
                </li>
              ))}
            </ul>

            <div class="mt-5 flex flex-wrap gap-2">
              {exp.tech.map((tech) => (
                <span class="chip">{tech}</span>
              ))}
            </div>
          </div>
        </Reveal>
      ))}
    </div>
  </div>
</section>
