---
const projects = [
  {
    title: 'Job Queue & Worker System',
    description:
      'A Redis-based job queue with priority handling, retries, and crash-safe processing.',
    tech: ['Go', 'Redis', 'Concurrency'],
    link: '#',
  },
  {
    title: 'Media Social API',
    description:
      'Secure auth with JWT, refresh token rotation, and device-based login.',
    tech: ['Go', 'PostgreSQL', 'JWT'],
    link: '#',
  },
  {
    title: 'Authentication Service',
    description:
      'Secure auth with JWT, refresh token rotation, and device-based login.',
    tech: ['Go', 'PostgreSQL', 'JWT'],
    link: '#',
  },
  {
    title: 'Authentication Service',
    description:
      'Secure auth with JWT, refresh token rotation, and device-based login.',
    tech: ['Go', 'PostgreSQL', 'JWT'],
    link: '#',
  },
];
---

<section id="projects" class="relative py-25 px-6">
  <div class="max-w-6xl mx-auto text-center mb-16">
    <p class="text-sm uppercase tracking-widest text-indigo-400 mb-3">
      Selected Work
    </p>
    <h2 class="text-3xl md:text-4xl font-bold text-slate-100">
      Projects
    </h2>
    <p class="mt-4 max-w-2xl mx-auto text-slate-400">
      A collection of things I’ve built, focusing on backend systems,
      performance, and clean architecture.
    </p>
  </div>

  <div class="max-w-6xl mx-auto grid gap-6 md:grid-cols-2">
      {projects.map((p) => (
        <div class="rounded-2xl bg-white/5 backdrop-blur border border-white/10 p-6 hover:bg-white/10 transition">
          <h3 class="text-xl font-semibold text-slate-100 mb-2">{p.title}</h3>
          <p class="text-slate-400 text-sm">{p.description}</p>

          <div class="mt-4 flex flex-wrap gap-2 text-xs text-slate-300">
            {p.tech.map((t) => (
              <span class="px-2 py-1 rounded-md bg-white/5 border border-white/10">
                {t}
              </span>
            ))}
          </div>

          <a href={p.link} class="inline-block mt-6 text-indigo-400 hover:text-indigo-300">
            View Project →
          </a>
        </div>
      ))}
    </div>
</section>
