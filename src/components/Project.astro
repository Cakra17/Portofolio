---
import { Icon } from 'astro-icon/components';
import Reveal from './Reveal.astro';
import { projects } from '../data/projects';
---

<section id="projects" class="relative py-25">
  <div class="section-shell">
    <Reveal class="mx-auto mb-16 max-w-2xl text-center">
      <p class="eyebrow mb-3">Selected Work</p>
      <h2 class="text-3xl font-bold text-text md:text-4xl">Projects</h2>
      <p class="mt-4 text-muted">
        A collection of things I've built, focusing on backend systems,
        performance, and clean architecture.
      </p>
    </Reveal>

    <div class="grid gap-6 md:grid-cols-2">
      {projects.map((p, i) => (
        <Reveal delay={i * 80}>
          <article class="card card-hover group flex h-full flex-col p-6">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-xl font-semibold text-text">{p.title}</h3>
              <a
                href={p.link}
                target="_blank"
                rel="noopener"
                aria-label={`Open ${p.title} on GitHub`}
                class="text-muted transition group-hover:text-accent"
              >
                <Icon name="lucide:arrow-up-right" class="h-5 w-5" />
              </a>
            </div>

            <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">
              {p.description}
            </p>

            <div class="mt-5 flex flex-wrap gap-2">
              {p.techs.map((tech) => (
                <span class="chip">{tech}</span>
              ))}
            </div>
          </article>
        </Reveal>
      ))}
    </div>
  </div>
</section>
