---
const projects = [
  {
    title: 'TQ',
    description:
      `TQ is a Go-based task queue system that enables asynchronous processing of background jobs. 
      It provides a robust foundation for handling time-consuming operations outside of the main application flow, 
      improving application responsiveness and enabling horizontal scaling of worker processes.`,
    techs: ['Go', 'Redis', 'Concurrency'],
    link: 'https://github.com/Cakra17/tq',
  },
  {
    title: 'Media Social API',
    description:
      `Social API is a backend service implemented in Go that provides core API endpoints for a social platform. 
      It is designed to be simple, modular, and ready for extension.`,
    techs: ['Go', 'PostgreSQL', 'JWT'],
    link: 'https://github.com/Cakra17/social',
  },
  {
    title: 'IMPHNEN',
    description:
      `A comprehensive platform designed to help Indonesian UMKM (Micro, Small, and Medium Enterprises) 
      automate financial record-keeping through AI-powered receipt scanning and streamline order management 
      via Telegram bot integration.`,
    techs: ['Go', 'PostgreSQL', 'Python', 'Kolosal AI', 'Svelte', 'TS'],
    link: 'https://github.com/Cakra17/IMPHNEN',
  },
  {
    title: 'Schemazz',
    description:
      `Schemazz is an interactive application that allows developers and database administrators to 
      visualize database structures by converting SQL queries into clear, readable ERD diagrams. 
      Built with modern web technologies, it provides a fast and intuitive way to understand database 
      relationships and schema design.`,
    techs: ['React', 'TS', 'Tailwind'],
    link: 'https://github.com/Cakra17/Schemazz',
  },
  {
    title: 'Paku',
    description:
      `PAKU (Presensi Akurat Klinik Asih Pratama Asih Usadha) is a mobile application developed to streamline 
      attendance management and personnel administration for medical staff and employees at clinical healthcare 
      facilities.`,
    techs: ['Express', 'MySQL', 'React', 'Kotlin'],
    link: 'https://github.com/orgs/Capstone-Project-PAKU/repositories',
  },
];
---

<section id="projects" class="relative py-25 px-6">
  <div class="max-w-6xl mx-auto text-center mb-16">
    <p class="text-sm uppercase tracking-widest text-indigo-400 mb-3">
      Selected Work
    </p>
    <h2 class="text-3xl md:text-4xl font-bold text-slate-100">
      Projects
    </h2>
    <p class="mt-4 max-w-2xl mx-auto text-slate-400">
      A collection of things I’ve built, focusing on backend systems,
      performance, and clean architecture.
    </p>
  </div>

  <div class="max-w-6xl mx-auto grid gap-6 md:grid-cols-2">
      {projects.map((p) => (
        <div class="rounded-2xl bg-white/5 backdrop-blur border border-white/10 p-6 hover:bg-white/10 transition">
          <h3 class="text-xl font-semibold text-slate-100 mb-2">{p.title}</h3>
          <p class="text-slate-400 text-sm">{p.description}</p>

          <div class="mt-4 flex flex-wrap gap-2 text-xs text-slate-300">
            {p.techs.map((tech) => (
              <span class="px-2 py-1 rounded-md bg-white/5 border border-white/10">
                {tech}
              </span>
            ))}
          </div>

          <a href={p.link} target="_blank" class="inline-block mt-6 text-indigo-400 hover:text-indigo-300">
            View Project →
          </a>
        </div>
      ))}
    </div>
</section>
