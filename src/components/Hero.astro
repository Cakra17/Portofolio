---
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';
import { skills } from '../data/skills';
---

<section
  id="about"
  class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-24"
>
  <!-- Background glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10"
  >
    <div
      class="absolute left-1/2 top-1/4 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full opacity-20 blur-3xl"
      style="background: radial-gradient(circle, rgb(var(--glow) / 0.6), transparent 60%);"
    >
    </div>
    <div
      class="absolute inset-0 -z-10 opacity-[0.04]"
      style="background-image: radial-gradient(rgb(var(--glow)) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>
  </div>

  <div class="max-w-3xl text-center">
    <p class="eyebrow mb-5">{site.role}</p>

    <h1 class="text-4xl font-bold tracking-tight text-text sm:text-5xl md:text-6xl">
      Hi, I'm
      <span class="text-accent">{site.shortName}</span>
      <br class="hidden sm:block" />
      {site.tagline[0]} <span class="text-accent">{site.tagline[1]}</span>
    </h1>

    <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-muted md:text-lg">
      {site.bio}
    </p>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a href={site.cv} target="_blank" rel="noopener" class="btn-primary">
        <Icon name="lucide:download" class="h-4 w-4" />
        Download CV
      </a>
      <a href="#contact" class="btn-ghost">
        <Icon name="lucide:mail" class="h-4 w-4" />
        Contact Me
      </a>
    </div>

    <div class="mt-12">
      <p class="mb-4 font-mono text-xs uppercase tracking-widest text-muted">
        Tech I work with
      </p>
      <div class="flex flex-wrap items-center justify-center gap-2.5">
        {skills.map((tech) => (
          <span class="chip hover:border-accent/40 hover:text-text transition">
            <img src={tech.logo} alt={tech.name} class="h-4 w-4" />
            {tech.name}
          </span>
        ))}
      </div>
    </div>

    <!-- Scroll hint -->
    <a
      href="#projects"
      aria-label="Scroll to projects"
      class="mt-16 inline-flex items-center gap-2 font-mono text-xs text-muted transition hover:text-accent"
    >
      <span class="animate-bounce"><Icon name="lucide:chevron-down" class="h-4 w-4" /></span>
      Scroll
    </a>
  </div>
</section>
