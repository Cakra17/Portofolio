---
import { Icon } from 'astro-icon/components';
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-border">
  <div class="section-shell flex flex-col items-center justify-between gap-4 py-10 sm:flex-row">
    <p class="font-mono text-sm text-muted">
      &copy; {year} {site.brand}
    </p>

    <!-- <p class="text-sm text-muted"> -->
    <!--   Built with Astro &amp; Tailwind -->
    <!-- </p> -->

    <div class="flex items-center gap-2">
      <a
        href={site.social.github}
        target="_blank"
        rel="noopener"
        aria-label="GitHub"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-surface-2 text-muted transition hover:text-accent hover:border-accent/40"
      >
        <Icon name="lucide:github" class="h-4 w-4" />
      </a>
      <a
        href={site.social.linkedin}
        target="_blank"
        rel="noopener"
        aria-label="LinkedIn"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-surface-2 text-muted transition hover:text-accent hover:border-accent/40"
      >
        <Icon name="lucide:linkedin" class="h-4 w-4" />
      </a>
      <a
        href={`mailto:${site.email}`}
        aria-label="Email"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-border bg-surface-2 text-muted transition hover:text-accent hover:border-accent/40"
      >
        <Icon name="lucide:mail" class="h-4 w-4" />
      </a>
    </div>
  </div>
</footer>
